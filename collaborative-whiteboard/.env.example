# Copy this file to .env before running docker compose if you want custom values.

MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_DATABASE=whiteboard_db
MYSQL_USER=whiteboard_user
MYSQL_PASSWORD=change_this_app_password

FRONTEND_PORT=3000

# Defaults below make the frontend call nginx, which proxies to the backend.
# For separate domains, set full URLs, for example:
# VITE_API_BASE_URL=https://api.example.com/api
# VITE_WS_URL=wss://api.example.com/ws/drawing
VITE_API_BASE_URL=/api
VITE_WS_URL=/ws/drawing
